generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Niche {
  REAL_ESTATE
  ESIGN
  LEGAL
  HR
  SUPPORT
}

enum UserRole {
  TENANT_ADMIN
  TENANT_OPERATOR
  KDL_APPROVER
  PLATFORM_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

// ─── Tenant ───────────────────────────────────────────────────────────────────

model Tenant {
  id             String       @id @default(uuid())
  slug           String       @unique
  name           String
  niche          Niche
  status         TenantStatus @default(ACTIVE)
  allowedDomains String[]
  plan           String       @default("FREE")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  settings      TenantSettings?
  users         User[]
  apiKeys       ApiKey[]
  agents             Agent[]
  roles              AgentRole[]
  knowledgeDocuments KnowledgeDocument[]
  conversations      Conversation[]
  departments        Department[]
  crews        Crew[]
  crewMembers  CrewMember[]
  crewWorkflows CrewWorkflow[]
  usageLimit   TenantUsageLimit?
  usageCurrent TenantUsageCurrent[]

  @@map("tenants")
}

model TenantSettings {
  id               String  @id @default(uuid())
  tenantId         String  @unique
  dpoName          String?
  dpoEmail         String?
  privacyPolicyUrl String?
  dataRetentionDays Int    @default(90)
  kdlOptOut        Boolean @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id             String     @id @default(uuid())
  tenantId       String?
  email          String     @unique
  name           String
  passwordHash   String
  role           UserRole
  status         UserStatus @default(ACTIVE)
  failedAttempts Int        @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  tenant        Tenant?        @relation(fields: [tenantId], references: [id])
  refreshTokens RefreshToken[]

  @@index([tenantId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tenantId  String?
  tokenHash String    @unique
  family    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([family])
  @@index([userId])
  @@map("refresh_tokens")
}

model ApiKey {
  id         String       @id @default(uuid())
  tenantId   String
  keyPrefix  String
  keyHash    String       @unique
  status     ApiKeyStatus @default(ACTIVE)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime     @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([keyPrefix])
  @@index([tenantId])
  @@map("api_keys")
}

// ─── Agent ────────────────────────────────────────────────────────────────────

enum AgentType {
  SDR
  HELPDESK
  NEGOTIATION
  ONBOARDING
  SUPPORT
  SALES
}

enum AgentStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum PromptVersionStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
}

model Agent {
  id                  String      @id @default(uuid())
  tenantId            String
  name                String
  slug                String
  type                AgentType
  category            String
  roleId              String
  operationalFunction String
  description         String?
  status              AgentStatus @default(DRAFT)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Contexto Organizacional & Responsável
  departmentId        String?
  directorId          String?
  mainChannel         String?

  // Comportamento & Autonomia
  toneOfVoice        String?
  communicationStyle String?
  autonomyLevel      String?
  responsibilities   Json        @default("[]")

  // Permissões e Ferramentas
  permissionReadKB         Boolean   @default(true)
  permissionSendWhatsapp   Boolean   @default(false)
  permissionSendEmail      Boolean   @default(false)
  permissionExecuteTool    Boolean   @default(false)
  permissionCallHuman      Boolean   @default(false)
  permissionCreateTask     Boolean   @default(false)
  permissionReadHistory    Boolean   @default(false)
  permissionReadCommercial Boolean   @default(false)

  // System Prompt Customizado (Complementos)
  outputFormat       String?
  expectedExamples   String?
  specificRules      String?

  // Qualificação de Leads
  qualificationSchemaId String? // optional — links to QualificationSchema for this agent's niche

  // Relações
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department      Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  promptVersions  AgentPromptVersion[]
  conversations   Conversation[]
  crewMemberships CrewMember[]
  role            AgentRole            @relation(fields: [roleId], references: [id])
  director        Agent?               @relation("AgentDirector", fields: [directorId], references: [id], onDelete: SetNull)
  subordinates    Agent[]              @relation("AgentDirector")

  @@unique([tenantId, name])
  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([roleId])
  @@index([departmentId])
  @@map("agents")
}

model AgentRole {
  id          String   @id @default(uuid())
  tenantId    String?
  name        String
  category    String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agents Agent[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("agent_roles")
}

model AgentPromptVersion {
  id           String              @id @default(uuid())
  agentId      String
  tenantId     String
  systemPrompt String
  version      Int
  status       PromptVersionStatus @default(DRAFT)
  createdAt    DateTime            @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([tenantId])
  @@map("agent_prompt_versions")
}

// ─── Knowledge ────────────────────────────────────────────────────────────────

enum KnowledgeLayer {
  GLOBAL
  INDUSTRY
  TENANT
  AGENT
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model KnowledgeDocument {
  id          String         @id @default(uuid())
  tenantId    String?
  agentId     String?
  layer       KnowledgeLayer
  title       String
  content     String
  contentHash String
  status      DocumentStatus @default(PENDING)
  chunksCount Int            @default(0)
  niche       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chunks KnowledgeChunk[]

  @@index([tenantId, layer])
  @@index([contentHash])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id         String   @id @default(uuid())
  documentId String
  tenantId   String?
  chunkIndex Int
  content    String
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime @default(now())

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([tenantId])
  @@map("knowledge_chunks")
}

// ─── Conversation ─────────────────────────────────────────────────────────────

enum ConversationStatus {
  OPEN
  CLOSED
  ACTIVE
  WAITING_USER
  WAITING_AGENT
  HANDOFF_REQUESTED
  HANDOFF_ACCEPTED
  REOPENED
  ARCHIVED
  TRANSFERRED_TO_HUMAN
}

enum MessageRole {
  USER
  ASSISTANT
  OPERATOR
}

model Conversation {
  id             String             @id @default(uuid())
  tenantId       String
  agentId        String
  crewId         String?
  externalUserId String?
  status         ConversationStatus @default(OPEN)
  messageCount   Int                @default(0)
  workflowState  Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent    Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  crew     Crew?     @relation(fields: [crewId], references: [id], onDelete: Cascade)
  messages Message[]
  lifecycleEvents ConversationLifecycleEvent[]
  humanHandoff HumanHandoff?

  @@index([tenantId])
  @@index([tenantId, agentId])
  @@index([externalUserId])
  @@index([crewId])
  @@map("conversations")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  tenantId       String
  role           MessageRole
  content        String
  metadata       Json?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([tenantId])
  @@map("messages")
}

// ─── Human Handoff ────────────────────────────────────────────────────────────

model HumanHandoff {
  id             String    @id @default(cuid())
  tenantId       String
  conversationId String    @unique
  reason         String
  contactPhone   String?
  webhookSent    Boolean   @default(false)
  waSentAt       DateTime?
  webhookSentAt  DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([tenantId])
  @@map("human_handoffs")
}

// ─── Organization ─────────────────────────────────────────────────────────────

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

model Department {
  id          String           @id @default(uuid())
  tenantId    String
  name        String
  slug        String
  description String?
  status      DepartmentStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  crews  Crew[]
  agents Agent[]

  @@unique([tenantId, name])
  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("departments")
}

// ─── Crew ─────────────────────────────────────────────────────────────────────

enum CrewStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum CrewMemberRole {
  DIRECTOR
  MEMBER
  OBSERVER
}

model Crew {
  id           String     @id @default(uuid())
  tenantId     String
  departmentId String
  name         String
  slug         String
  description  String?
  objective    String?
  status       CrewStatus @default(DRAFT)
  humanHandoffWhatsappNumber String?
  humanHandoffWebhookUrl     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  members    CrewMember[]
  conversations Conversation[]
  workflow   CrewWorkflow?

  @@unique([tenantId, name])
  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([departmentId])
  @@map("crews")
}

model CrewMember {
  id         String         @id @default(uuid())
  tenantId   String
  crewId     String
  agentId    String
  role       CrewMemberRole @default(MEMBER)
  order      Int            @default(0)
  isRequired Boolean        @default(true)
  createdAt  DateTime       @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  crew   Crew   @relation(fields: [crewId], references: [id], onDelete: Cascade)
  agent  Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([crewId, agentId])
  @@index([tenantId])
  @@index([crewId])
  @@map("crew_members")
}

model CrewWorkflow {
  id        String   @id @default(uuid())
  tenantId  String
  crewId    String   @unique
  nodes     Json     @default("[]")
  edges     Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  crew   Crew   @relation(fields: [crewId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("crew_workflows")
}

// ─── Qualification ────────────────────────────────────────────────────────────

model QualificationSchema {
  id        String   @id @default(uuid())
  tenantId  String?  // null = global (platform-level, read-only for tenants)
  nicheKey  String
  version   Int      @default(1)
  fields    Json     @default("[]")  // FieldDef[]
  order     Json     @default("[]")  // string[] — collection order
  createdAt DateTime @default(now())

  states QualificationState[]

  @@unique([tenantId, nicheKey, version])
  @@index([tenantId])
  @@map("qualification_schemas")
}

model QualificationState {
  id             String   @id @default(uuid())
  conversationId String   @unique
  tenantId       String
  agentId        String
  schemaId       String?  // nullable during backfill; links to QualificationSchema
  stage          String   @default("QUALIFYING")
  lastIntent     String?
  fields         Json     @default("{}")
  updatedAt      DateTime @updatedAt

  schema QualificationSchema? @relation(fields: [schemaId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("qualification_states")
}

// ─── Audit ────────────────────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid())
  tenantId     String?
  userId       String?
  action       String
  resourceId   String?
  resourceType String?
  metadata     Json?
  ip           String?
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Usage Limits ─────────────────────────────────────────────────────────────

model TenantUsageLimit {
  id                 String   @id @default(uuid())
  tenantId           String   @unique
  messagesPerMonth   Int      @default(1000)
  tokensPerMonth     Int      @default(1000000)
  costPerMonthUsd    Float    @default(10.0)
  messagesPerMinute  Int      @default(30)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_usage_limits")
}

model TenantUsageCurrent {
  id                 String    @id @default(uuid())
  tenantId           String
  yearMonth          String
  messages           Int       @default(0)
  inputTokens        Int       @default(0)
  outputTokens       Int       @default(0)
  totalTokens        Int       @default(0)
  estimatedCostUsd   Float     @default(0)
  messagesLastMinute Int       @default(0)
  lastMessageAt      DateTime?
  needsNotification  Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, yearMonth])
  @@index([tenantId])
  @@map("tenant_usage_current")
}

model InboundEvent {
  id                      String   @id @default(uuid())
  tenantId                String
  channel                 String
  provider                String
  providerMessageId       String
  providerConversationId  String?
  contactExternalId       String
  rawPayload              Json
  normalizedPayload       Json?
  status                  String   @default("RECEIVED")
  attemptCount            Int      @default(0)
  receivedAt              DateTime
  processedAt             DateTime?
  error                   String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([tenantId, provider, providerMessageId])
  @@index([tenantId, status])
  @@map("inbound_events")
}

model Contact {
  id        String   @id @default(uuid())
  tenantId  String
  name      String?
  email     String?
  phone     String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  identities ContactChannelIdentity[]

  @@index([tenantId])
  @@map("contacts")
}

model ContactChannelIdentity {
  id           String   @id @default(uuid())
  tenantId     String
  contactId    String
  channel      String
  provider     String
  externalId   String
  phoneNumber  String?
  emailAddress String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([tenantId, channel, provider, externalId])
  @@index([tenantId])
  @@index([contactId])
  @@map("contact_channel_identities")
}

model ConversationLifecycleEvent {
  id             String   @id @default(uuid())
  tenantId       String
  conversationId String
  fromStatus     String
  toStatus       String
  actor          String
  actorId        String?
  reason         String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([conversationId])
  @@map("conversation_lifecycle_events")
}

model AgentExecutionTrace {
  id               String   @id @default(uuid())
  tenantId         String
  conversationId   String
  inboundEventId   String?
  agentId          String
  crewId           String?
  channel          String
  promptVersionId  String?
  model            String?
  inputTokens      Int      @default(0)
  outputTokens     Int      @default(0)
  totalTokens      Int      @default(0)
  estimatedCostUsd Float    @default(0)
  chunksUsed       String[]
  memoryBlocksUsed String[]
  queueWaitMs      Int?
  llmDurationMs    Int?
  durationMs       Int      @default(0)
  status           String
  error            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId])
  @@index([conversationId])
  @@map("agent_execution_traces")
}

model ConversationSummary {
  id                      String   @id @default(uuid())
  tenantId                String
  conversationId          String   @unique
  summary                 String
  lastSummarizedMessageId String
  summaryVersion          Int      @default(1)
  tokenCount              Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([tenantId])
  @@map("conversation_summaries")
}

model ContactMemory {
  id                   String   @id @default(uuid())
  tenantId             String
  contactId            String
  memoryType           String
  content              String
  sourceConversationId String
  confidence           Float    @default(1.0)
  status               String
  shouldPersist        Boolean  @default(true)
  expiresAt            DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([tenantId])
  @@index([contactId])
  @@map("contact_memories")
}

enum KDLInsightStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

model KDLInsight {
  id              String           @id @default(uuid())
  niche           Niche
  questionPattern String
  answerPattern   String
  sourceCount     Int              @default(1)
  confidence      Float
  status          KDLInsightStatus @default(PENDING_REVIEW)
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime         @default(now())

  @@map("kdl_insights")
}

// ─── Channels ──────────────────────────────────────────────────────────────────

model ChannelConfig {
  id              String   @id @default(uuid())
  tenantId        String
  provider        String   // 'WHATSAPP' | 'EMAIL'
  phoneNumberId   String?  // WhatsApp: Business phone number ID
  accessToken     String?  // Criptografado
  webhookSecret   String?  // Criptografado
  fromAddress     String?  // Email: endereço de envio
  fromName        String?
  sendgridApiKey  String?  // Criptografado
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([provider, phoneNumberId])
  @@unique([provider, fromAddress])
  @@index([tenantId])
  @@map("channel_configs")
}
